{
	"servers": {
		"microsoft/playwright-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.1-seed"
		},
		"github/github-mcp-server": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@anthropic/github-mcp-server@latest"
			],
			"env": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github_pat}"
			}
		},
		"supabase/supabase-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@supabase/mcp-server-supabase@latest",
				"--access-token",
				"sbp_1a48bdc17af4c6d38d4634b328a6ce80a0bbfa49",
				"--project-ref",
				"cvjyorwkcndpiwnpywqu"
			]
		},
		"redis-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@redis/mcp@latest",
				"--url",
				"redis://localhost:6380"
			]
		},
		"fetch-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@anthropic/mcp-fetch@latest"
			]
		},
	
		"stitch": {
			"url": "https://stitch.googleapis.com/mcp",
			"type": "http",
			"headers": {
				"Accept": "application/json",
				"X-Goog-Api-Key": "${input:google_stitch_api_key}"
			}
		}
	},
	"inputs": [
		{
			"id": "github_pat",
			"description": "GitHub Personal Access Token (repo, read:org scopes)",
			"type": "promptString",
			"password": true
		},
		{
			"id": "supabase_access_token",
			"description": "Supabase Personal Access Token (from https://supabase.com/dashboard/account/tokens)",
			"type": "promptString",
			"password": true
		},
		{
			"id": "redis_url",
			"description": "Redis connection URL (e.g. redis://localhost:6379 or Redis Cloud URL)",
			"type": "promptString",
			"password": true
		},
		{
			"id": "token",
			"type": "promptString",
			"description": "",
			"password": true
		},
		{
			"id": "google_stitch_api_key",
			"description": "Google Stitch API Key",
			"type": "promptString",
			"password": true
		}
	]
}